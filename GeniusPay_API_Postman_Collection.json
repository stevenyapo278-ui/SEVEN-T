{
  "info": {
    "name": "GeniusPay API Marchand",
    "description": "Collection Postman pour l'API Marchand GeniusPay - Intégrez les paiements mobiles et par carte en quelques minutes.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "version": "1.0.0"
  },
  "auth": {
    "type": "apikey",
    "apikey": [
      {
        "key": "value",
        "value": "{{api_key}}",
        "type": "string"
      },
      {
        "key": "key",
        "value": "X-API-Key",
        "type": "string"
      }
    ]
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://pay.genius.ci/api/v1/merchant",
      "type": "string"
    },
    {
      "key": "api_key",
      "value": "pk_sandbox_xxxxxxxx",
      "type": "string"
    },
    {
      "key": "api_secret",
      "value": "sk_sandbox_xxxxxxxx",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Paiements",
      "item": [
        {
          "name": "Créer un paiement (Mode Checkout)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "X-API-Key",
                "value": "{{api_key}}",
                "type": "text"
              },
              {
                "key": "X-API-Secret",
                "value": "{{api_secret}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"amount\": 15000,\n  \"description\": \"Commande #12345\",\n  \"customer\": {\n    \"name\": \"Amadou Diallo\",\n    \"email\": \"amadou@example.com\",\n    \"phone\": \"+221771234567\"\n  },\n  \"success_url\": \"https://monsite.com/success\",\n  \"error_url\": \"https://monsite.com/error\",\n  \"metadata\": {\n    \"order_id\": \"12345\",\n    \"customer_id\": \"CUST-001\"\n  }\n}"
            },
            "url": {
              "raw": "{{base_url}}/payments",
              "host": ["{{base_url}}"],
              "path": ["payments"]
            },
            "description": "Crée un paiement sans spécifier de méthode. Le client choisira sur la page de checkout GeniusPay."
          },
          "response": []
        },
        {

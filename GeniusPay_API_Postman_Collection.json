        {
          "name": "Lister les paiements",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "X-API-Key",
                "value": "{{api_key}}",
                "type": "text"
              },
              {
                "key": "X-API-Secret",
                "value": "{{api_secret}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/payments?per_page=20",
              "host": ["{{base_url}}"],
              "path": ["payments"],
              "query": [
                {
                  "key": "status",
                  "value": "completed",
                  "disabled": true
                },
                {
                  "key": "from",
                  "value": "2025-01-01",
                  "disabled": true
                },
                {
                  "key": "to",
                  "value": "2025-12-31",
                  "disabled": true
                },
                {
                  "key": "per_page",
                  "value": "20"
                }
              ]
            },
            "description": "Liste tous les paiements avec filtres optionnels."
          },
          "response": []
        },

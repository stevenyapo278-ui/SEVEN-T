# ==========================================
# SEVEN T — Production Environment Variables
# ==========================================
# IMPORTANT: This file must NEVER be committed to git.
# .gitignore must contain: .env.production
#
# Generate secrets with:
#   JWT_SECRET=$(openssl rand -base64 64)
#   ENCRYPTION_KEY=$(openssl rand -hex 32)
#   REDIS_PASSWORD=$(openssl rand -hex 24)
#   POSTGRES_PASSWORD=$(openssl rand -hex 24)
# ==========================================

# ── Server ───────────────────────────────
NODE_ENV=production
PORT=3001

# ── URLs ─────────────────────────────────
FRONTEND_URL=https://votre-domaine.com
ALLOWED_ORIGINS=https://votre-domaine.com
BASE_URL=https://votre-domaine.com

# ── Security (generate with openssl, see above) ──
JWT_SECRET=CHANGE_ME_generate_with_openssl_rand_base64_64
ENCRYPTION_KEY=CHANGE_ME_generate_with_openssl_rand_hex_32
JWT_EXPIRES_IN=7d

# ── Database ─────────────────────────────
DATABASE_URL=postgres://seven_t:CHANGE_ME@postgres:5432/seven_t_db
POSTGRES_USER=seven_t
POSTGRES_PASSWORD=CHANGE_ME_generate_with_openssl_rand_hex_24
POSTGRES_DB=seven_t_db

# ── Redis ─────────────────────────────────
REDIS_URL=redis://:CHANGE_ME@redis:6379
REDIS_PASSWORD=CHANGE_ME_generate_with_openssl_rand_hex_24

# ── AI Providers ─────────────────────────
GEMINI_API_KEY=
OPENAI_API_KEY=
OPENROUTER_API_KEY=

# ── Email / SMTP ─────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=SEVEN T <noreply@seven-t.com>

# ── OAuth Google ─────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Payment Providers ─────────────────────
GENIUSPAY_API_KEY=
GENIUSPAY_API_SECRET=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ── Admin ────────────────────────────────
ADMIN_EMAIL=admin@votre-domaine.com
DOMAIN=votre-domaine.com

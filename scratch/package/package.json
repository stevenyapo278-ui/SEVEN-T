{
    "name": "motion-studio-mcp",
    "version": "5.4.3",
    "private": true,
    "type": "module",
    "author": {
        "name": "Matt Perry",
        "url": "https://motion.dev"
    },
    "license": "MIT",
    "repository": "https://github.com/motiondivision/plus",
    "main": "./dist/es/index.mjs",
    "bin": "./dist/es/index.mjs",
    "types": "./dist/index.d.ts",
    "module": "./dist/es/index.mjs",
    "sideEffects": false,
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/es/index.mjs",
            "default": "./dist/es/index.mjs"
        }
    },
    "dependencies": {
        "@modelcontextprotocol/sdk": "^1.12.1",
        "fuse.js": "^7.1.0",
        "motion-dom": "^12.16.0",
        "motion-utils": "^12.12.1",
        "sharp": "^0.34.2",
        "ws": "^8.19.0",
        "zod": "^3.25.56"
    },
    "scripts": {
        "clean": "rm -rf types dist lib",
        "build": "yarn clean && tsc -p . && rollup -c",
        "new-package": "../../scripts/new.sh mcp",
        "dev": "concurrently -c blue,red -n tsc,rollup --kill-others \"tsc --watch -p . --preserveWatchOutput\" \"rollup --config --watch --no-watch.clearScreen\""
    },
    "gitHead": "23a64c03071bf30713127b83a42cc4485bd854b0",
    "devDependencies": {
        "@types/ws": "^8.18.1"
